set.seed(17765673)
tamanhos <- c(10, 100, 1000)
resultados <- list()
for (n in tamanhos) {
# Simulação
G <- rnorm(n, mean = 0, sd = 1)
E <- rnorm(n, mean = 0, sd = 1)
P <- G + E
# Estatísticas
medias <- c(mean(P), mean(G), mean(E))
variancias <- c(var(P), var(G), var(E))
print(paste("Tamanho:", n))
print(paste("Médias (P, G, E):", round(medias, 3)))
print(paste("Variâncias (P, G, E):", round(variancias, 3)))
# Salvar resultados
resultados[[paste0("n_", n)]] <- list(P = P, G = G, E = E)
# Gráficos
par(mfrow = c(2, 2))  # 4 gráficos por vez
# Histograma
hist(P, main = paste("Histograma P (n =", n, ")"), col = "lightblue")
# Densidade
plot(density(P), main = paste("Densidade P (n =", n, ")"), col = "blue")
# Boxplot
boxplot(P, G, E, names = c("P", "G", "E"),
main = paste("Boxplot (n =", n, ")"),
col = c("red", "green", "gray"))
# Scatter plot P vs G
plot(G, P,
main = paste("P vs G (n =", n, ")"),
xlab = "G", ylab = "P",
pch = 19, col = "darkblue")
}
boxplot(P, G, E,
names = c("P", "G", "E"),
main = paste("Boxplot (n =", n, ")"),
)
